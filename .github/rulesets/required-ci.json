{
  "name": "Required CI checks",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": ["refs/heads/main"],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "required_status_checks",
      "parameters": {
        "strict_required_status_checks_policy": false,
        "do_not_enforce_on_create": true,
        "required_status_checks": [
          { "context": "Ruff" },
          { "context": "pytest" },
          { "context": "HACS validate" },
          { "context": "hassfest" }
        ]
      }
    }
  ]
}
